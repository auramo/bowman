{
  "license": "MIT",
  "name": "bowman",
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.3.2"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:watch": "webpack --config webpack.config.js --watch",
    "build:server": "tsc -p tsconfig.server.json",
    "clean": "rm -rf dist/ dist-server/",
    "start": "node dist-server/server/server.js",
    "postinstall": "tsc -p tsconfig.server.json && webpack --config webpack.config.js",
    "watch": "yarn build:watch & yarn watch:server",
    "watch:server": "tsc -p tsconfig.server.json --watch & NODE_ENV=development nodemon -e js --watch dist-server dist-server/server/server.js",
    "create-migration": "./server/migration/create-migration.sh",
    "test": "mocha --require ts-node/register -R spec 'test/unit/**/*.ts'"
  },
  "devDependencies": {
    "@types/body-parser": "^1",
    "@types/chai": "^4",
    "@types/compression": "^1",
    "@types/connect-pg-simple": "^4",
    "@types/cookie-parser": "^1",
    "@types/express": "^4",
    "@types/express-session": "^1",
    "@types/lodash": "^4",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "@types/passport": "^1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/passport-google-oauth20": "^2",
    "@types/ramda": "^0",
    "@types/uuid": "^10",
    "chai": "^4.1.2",
    "css-loader": "^7",
    "html-webpack-plugin": "^5",
    "less": "^4",
    "less-loader": "^12",
    "mini-css-extract-plugin": "^2",
    "mocha": "^5.0.0",
    "nodemon": "^1.14.11",
    "style-loader": "^4",
    "ts-loader": "^9",
    "ts-node": "^10",
    "typescript": "^5",
    "webpack": "^5",
    "webpack-cli": "^5",
    "webpack-node-externals": "^3"
  },
  "dependencies": {
    "assert": "^1.4.1",
    "axios": "^0.17.1",
    "bluebird": "^3.5.1",
    "body-parser": "^1.17.2",
    "camelize": "^1.0.0",
    "compression": "^1.7.1",
    "connect-pg-simple": "^4.2.1",
    "cookie-parser": "^1.4.3",
    "date-fns": "^1.30.1",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^4.0.0",
